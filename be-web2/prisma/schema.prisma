generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event{
  id    Int   @id @default(autoincrement())
  name String
  categoryId   Int   @map("categoryId")
  pembicaraId Int @map("pembicaraId")
  location     String
  dateEvent    DateTime @map("date_event")
  description  String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  category     Category @relation(fields: [categoryId], references: [id])
  pembicara    Pembicara @relation(fields: [pembicaraId], references: [id])

  @@map("events")
}

model Pembicara{
  id Int @id @default(autoincrement())
  name String
  role String
  createdAt DateTime @default(now()) @map("created_at")

  events Event[]

  @@map("pembicara")
}

model Category{
  id Int @id @default(autoincrement())
  name String
  createdAt DateTime @default(now()) @map("created_at")

  events Event[]

  @@map("categories")
}

